<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="refresh" content="30">
  <title>Bus arrivals</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0f172a;
      color: #f1f5f9;
      min-height: 100vh;
      padding: 2rem 1rem;
    }

    .page-title {
      text-align: center;
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #64748b;
      margin-bottom: 2rem;
    }

    .stops-layout {
      display: flex;
      gap: 1.5rem;
      max-width: 900px;
      margin: 0 auto;
      align-items: start;
    }

    .stops-col {
      flex: 1;
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
    }

    .stop-card {
      background: #1e293b;
      border-radius: 1.5rem;
      padding: 2rem;
      box-shadow: 0 25px 50px rgba(0,0,0,0.4);
    }

    .stop-header {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #64748b;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #0f172a;
    }

    .line-section {
      margin-bottom: 1.5rem;
    }

    .line-section:last-child {
      margin-bottom: 0;
    }

    .line-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .line-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #dc2626;
      color: #fff;
      font-size: 0.85rem;
      font-weight: 800;
      min-width: 2.5rem;
      height: 2.5rem;
      padding: 0 0.5rem;
      border-radius: 0.5rem;
    }

    .arrivals {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .arrival {
      background: #0f172a;
      border-radius: 0.75rem;
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .destination {
      font-size: 0.85rem;
      color: #94a3b8;
      text-align: left;
      flex: 1;
    }

    .time {
      display: flex;
      align-items: baseline;
      gap: 0.25rem;
    }

    .minutes {
      font-size: 2rem;
      font-weight: 700;
      color: #38bdf8;
      line-height: 1;
    }

    .minutes.soon { color: #4ade80; }
    .minutes.now  { color: #facc15; }

    .unit {
      font-size: 0.85rem;
      color: #64748b;
    }

    .empty {
      color: #475569;
      font-size: 0.85rem;
      padding: 0.5rem 0;
    }

    .refreshed-at {
      text-align: center;
      margin-top: 2rem;
      font-size: 0.75rem;
      color: #334155;
    }
  </style>
</head>
<body>
  <p class="page-title">Next arrivals</p>

  <div class="stops-layout">
    <div class="stops-col">
      <%= render 'stop_card', stop: @stops[0] %>
      <%= render 'stop_card', stop: @stops[3] %>
    </div>
    <div class="stops-col">
      <%= render 'stop_card', stop: @stops[1] %>
      <%= render 'stop_card', stop: @stops[2] %>
    </div>
  </div>

  <p class="refreshed-at">Updated <%= Time.now.strftime("%H:%M:%S") %> &middot; refreshes every 30 s</p>
</body>
</html>
