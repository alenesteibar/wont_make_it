<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="refresh" content="30">
  <title>Stop <%= @stop[:stop_id] %> — Next arrivals</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0f172a;
      color: #f1f5f9;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    .stop-card {
      background: #1e293b;
      border-radius: 1.5rem;
      padding: 2rem;
      min-width: 320px;
      box-shadow: 0 25px 50px rgba(0,0,0,0.4);
    }

    .stop-header {
      font-size: 0.75rem;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      color: #64748b;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 1px solid #0f172a;
    }

    .line-section {
      margin-bottom: 1.5rem;
    }

    .line-section:last-child {
      margin-bottom: 0;
    }

    .line-header {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 0.75rem;
    }

    .line-badge {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: #dc2626;
      color: #fff;
      font-size: 0.85rem;
      font-weight: 800;
      min-width: 2.5rem;
      height: 2.5rem;
      padding: 0 0.5rem;
      border-radius: 0.5rem;
    }

    .arrivals {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .arrival {
      background: #0f172a;
      border-radius: 0.75rem;
      padding: 0.75rem 1rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1rem;
    }

    .destination {
      font-size: 0.85rem;
      color: #94a3b8;
      text-align: left;
      flex: 1;
    }

    .time {
      display: flex;
      align-items: baseline;
      gap: 0.25rem;
    }

    .minutes {
      font-size: 2rem;
      font-weight: 700;
      color: #38bdf8;
      line-height: 1;
    }

    .minutes.soon { color: #4ade80; }
    .minutes.now  { color: #facc15; }

    .unit {
      font-size: 0.85rem;
      color: #64748b;
    }

    .empty {
      color: #475569;
      font-size: 0.85rem;
      padding: 0.5rem 0;
    }

    .refreshed-at {
      margin-top: 2rem;
      font-size: 0.75rem;
      color: #334155;
      text-align: center;
    }
  </style>
</head>
<body>
  <div class="stop-card">
    <p class="stop-header">Stop <%= @stop[:stop_id] %> &middot; Next arrivals</p>

    <% @stop[:lines].each do |line_data| %>
      <div class="line-section">
        <div class="line-header">
          <span class="line-badge"><%= line_data[:line] %></span>
        </div>

        <% if line_data[:arrivals].any? %>
          <ul class="arrivals">
            <% line_data[:arrivals].first(3).each do |arrival| %>
              <li class="arrival">
                <span class="destination"><%= arrival[:destination] %></span>
                <div class="time">
                  <span class="minutes <%= arrival[:minutes] <= 1 ? 'now' : arrival[:minutes] <= 5 ? 'soon' : '' %>">
                    <%= arrival[:minutes] %>
                  </span>
                  <span class="unit">min</span>
                </div>
              </li>
            <% end %>
          </ul>
        <% else %>
          <p class="empty">No arrivals data available.</p>
        <% end %>
      </div>
    <% end %>

    <p class="refreshed-at">Updated <%= Time.now.strftime("%H:%M:%S") %> &middot; refreshes every 30 s</p>
  </div>
</body>
</html>
